"html": "{% set s = frappe.get_single(\"Dealership Settings\") %}<div style=\"font-family: Arial, sans-serif;\"><div style=\"display: flex; justify-content: space-between; align-items: flex-start;\"><div>{% if s.logo %}<img src=\"{{ s.logo }}\" style=\"max-height: 80px;\">{% endif %}<h2 style=\"margin: 5px 0; color: #1a3c6e;\">{{ s.dealership_name }}</h2><div style=\"font-size: 12px; color: #555;\">{{ s.address }}<br>{{ s.from_email }}</div></div><div style=\"text-align: right;\"><h1 style=\"color: #1a3c6e; margin-bottom: 10px;\">SALE INVOICE</h1><p><strong>Invoice No:</strong> {{ doc.name }}</p><p><strong>Sale Date:</strong> {{ doc.sale_date }}</p><p><strong>Payment Mode:</strong> {{ doc.payment_mode }}</p><p><strong>Status:</strong> <span style=\"background: #1a3c6e; color: white; padding: 3px 10px; border-radius: 10px; font-size: 11px;\">{{ doc.status }}</span></p></div></div><hr style=\"margin: 20px 0;\"><div style=\"display: flex; justify-content: space-between; gap: 20px;\"><div style=\"flex: 1;\"><h3 style=\"color: #1a3c6e;\">Customer</h3><p><strong>Name:</strong> {{ doc.customer_name }}</p>{% if doc.customer_phone %}<p><strong>Phone:</strong> {{ doc.customer_phone }}</p>{% endif %}{% if doc.customer_email %}<p><strong>Email:</strong> {{ doc.customer_email }}</p>{% endif %}</div><div style=\"flex: 1;\"><h3 style=\"color: #1a3c6e;\">Sales Consultant</h3><p><strong>Name:</strong> {{ doc.sales_consultant }}</p>{% if doc.referrer_name %}<p><strong>Referral:</strong> {{ doc.referrer_name }}</p>{% endif %}</div></div><hr style=\"margin: 20px 0;\"><div><h3 style=\"color: #1a3c6e;\">Vehicle Details</h3><p><strong>Vehicle:</strong> {{ doc.vehicle }}</p><p><strong>Selling Price:</strong> ₹ {{ doc.selling_price }}</p></div><div style=\"text-align: center; margin-top: 40px;\"><h4 style=\"color: #1a3c6e;\">Thank you for your purchase!</h4></div></div>",
