 "font_size": 14,
 "html": "<style>\n    body {\n        font-family: Arial;\n    }\n    .header {\n        text-align: center;\n        border-bottom: 2px solid black;\n        margin-bottom: 20px;\n    }\n    .title {\n        font-size: 24px;\n        font-weight: bold;\n    }\n    .section {\n        margin-top: 20px;\n    }\n    .table {\n        width: 100%;\n        border-collapse: collapse;\n    }\n    .table, .table th, .table td {\n        border: 1px solid black;\n        padding: 8px;\n    }\n    .low { background-color: #d4edda; }   /* green */\n    .medium { background-color: #fff3cd; } /* yellow */\n    .high { background-color: #f8d7da; }  /* red */\n    .highlight {\n        font-size: 18px;\n        font-weight: bold;\n        color: #000;\n    }\n    .footer {\n        margin-top: 40px;\n        font-size: 12px;\n        border-top: 1px solid #000;\n        padding-top: 10px;\n    }\n</style>\n\n<!-- Header -->\n<div class=\"header\">\n    <div class=\"title\">CONSULTING REPORT</div>\n    <p><b>Report No:</b> {{ doc.name }}</p>\n    <p><b>Date:</b> {{ doc.creation }}</p>\n    <p><b>Consultant:</b> {{ doc.assigned_consultant }}</p>\n</div>\n\n<!-- Vehicle Details -->\n<div class=\"section\">\n    <h4>Vehicle Details (Client Provided)</h4>\n    <p><b>Registration:</b> {{ doc.registration_number }}</p>\n    <p><b>Manufacturer:</b> {{ doc.manufacturer }}</p>\n    <p><b>Model:</b> {{ doc.model }}</p>\n    <p><b>Year:</b> {{ doc.year }}</p>\n</div>\n\n<!-- Findings -->\n<div class=\"section\">\n    <h4>Findings & Risk Analysis</h4>\n    <table class=\"table\">\n        <tr>\n            <th>Aspect</th>\n            <th>Observation</th>\n            <th>Risk Level</th>\n        </tr>\n\n        {% for row in doc.recommendations %}\n        <tr class=\"\n            {% if row.risk_level == 'Low' %} low\n            {% elif row.risk_level == 'Medium' %} medium\n            {% else %} high\n            {% endif %}\n        \">\n            <td>{{ row.area_of_inspection }}</td>\n            <td>{{ row.observation }}</td>\n            <td>{{ row.risk_level }}</td>\n        </tr>\n        {% endfor %}\n    </table>\n</div>\n\n<!-- Recommendation -->\n<div class=\"section\">\n    <h4>Final Recommendation</h4>\n    <p class=\"highlight\">{{ doc.final_recommendation }}</p>\n</div>\n\n<!-- Rationale -->\n<div class=\"section\">\n    <h4>Supporting Rationale</h4>\n    <p>{{ doc.rationale }}</p>\n</div>\n\n<!-- Signature -->\n<div class=\"section\">\n    <p>Consultant Signature: ______________________</p>\n    <p>Date: {{ frappe.utils.today() }}</p>\n</div>\n\n<!-- Disclaimer -->\n<div class=\"footer\">\n    <p>\n        This report is based on the information and inspection available at the time of evaluation.\n        The consultancy firm is not liable for any future discrepancies or hidden defects.\n    </p>\n</div>",
